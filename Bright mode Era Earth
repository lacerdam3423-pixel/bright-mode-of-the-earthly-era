-- BRIGHT MODE MOTO E40 (ECONOMIA EXTREMA - ZERO LAG)
local Lighting = game:GetService("Lighting")
local TweenService = game:GetService("TweenService")

-- 1. CONFIGURAÇÃO GLOBAL (NÃO PESA NO CELULAR)
local function AjustarGlobal()
    Lighting.Brightness = 0
    Lighting.GlobalShadows = false
    Lighting.Ambient = Color3.new(1, 1, 1)
    Lighting.OutdoorAmbient = Color3.new(1, 1, 1)
    Lighting.FogEnd = 999999
    
    -- Remove efeitos pesados que travam celulares básicos
    local atmos = Lighting:FindFirstChildOfClass("Atmosphere")
    if atmos then atmos:Destroy() end
end

-- 2. TRANSIÇÃO SUAVE (2 SEGUNDOS)
local function Suavizar(alvo)
    TweenService:Create(Lighting, TweenInfo.new(2), {ExposureCompensation = alvo}):Play()
end

local function Ciclo()
    if Lighting.ClockTime >= 6 and Lighting.ClockTime <= 18 then
        Suavizar(0.5) -- Dia
    else
        Suavizar(0.8) -- Noite
    end
end

-- 3. AJUSTE DE OBJETOS (VERSÃO ULTRA LEVE)
local function AplicarAjuste(obj)
    -- Desativa luzes dinâmicas (isso economiza muita bateria e FPS)
    if obj:IsA("Light") then
        obj.Enabled = false
    end
    
    if obj:IsA("BasePart") then
        obj.CastShadow = false -- Remove sombra (FPS Boost)
        
        -- Só muda se for estritamente necessário
        if obj.Material == Enum.Material.Neon then
            obj.Material = Enum.Material.Ice
        end
        
        -- Objetos invisíveis ficam 0.8 como pedido
        if obj.Transparency >= 0.98 then
            obj.Transparency = 0.8
        end
    end
end

-- 4. VARREDURA LENTA PARA MOTO E40 (NÃO TRAVA)
AjustarGlobal()

task.spawn(function()
    local itens = workspace:GetDescendants()
    for i = 1, #itens do
        local ok, err = pcall(function()
            AplicarAjuste(itens[i])
        end)
        
        -- Pausa a cada 50 itens para o Moto E40 respirar
        if i % 50 == 0 then 
            task.wait(0.05) 
        end
    end
end)

-- Monitora novos itens sem pesar
workspace.DescendantAdded:Connect(function(obj)
    task.wait(0.1) -- Espera um pouco antes de ajustar para evitar picos de lag
    AplicarAjuste(obj)
end)

-- 5. MANUTENÇÃO LEVE (A CADA 3 SEGUNDOS)
task.spawn(function()
    while true do
        AjustarGlobal()
        Ciclo()
        task.wait(3) -- Aumentado para 3 segundos para máxima performance
    end
end)

print("Bright Mode Moto E40: Ativado com foco em FPS!")

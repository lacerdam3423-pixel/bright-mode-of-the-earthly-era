--// SERVICES
local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")

--// CONFIG
local config = {
	DayExposure = 0.0,
	NightExposure = 0.1,
	UpdateDelay = 0.1
}

--// CRIAR OU PEGAR COLORCORRECTION
local colorCorrection = Lighting:FindFirstChild("BrightMode_CC")
if not colorCorrection then
	colorCorrection = Instance.new("ColorCorrectionEffect")
	colorCorrection.Name = "BrightMode_CC"
	colorCorrection.Parent = Lighting
end

--// REMOVER NEVOA
Lighting.FogEnd = 1e10
Lighting.FogStart = 1e10
Lighting.FogColor = Color3.new(1,1,1)

--// ILUMINAÇÃO BASE
Lighting.Brightness = 3
Lighting.ClockTime = Lighting.ClockTime -- mantém ciclo
Lighting.GlobalShadows = false
Lighting.OutdoorAmbient = Color3.new(1,1,1)
Lighting.Ambient = Color3.new(1,1,1)

--// FUNÇÃO DIA/NOITE
local function isDay()
	local t = Lighting.ClockTime
	return t >= 6 and t <= 18
end

--// OTIMIZAÇÃO: PROCESSAR PARTES
local function optimizePart(obj)
	if obj:IsA("BasePart") then
		
		-- PRETO -> BRANCO
		if obj.Color.r < 0.1 and obj.Color.g < 0.1 and obj.Color.b < 0.1 then
			obj.Color = Color3.new(1,1,1)
		end
		
		-- NEON -> WOOD
		if obj.Material == Enum.Material.Neon then
			obj.Material = Enum.Material.Wood
		end
		
	end
end

--// PROCESSAR EXISTENTES (UMA VEZ)
for _, obj in ipairs(workspace:GetDescendants()) do
	optimizePart(obj)
end

--// NOVOS OBJETOS
workspace.DescendantAdded:Connect(function(obj)
	optimizePart(obj)
end)

--// LOOP PRINCIPAL
task.spawn(function()
	while true do
		
		-- EXPOSURE DINÂMICO
		if isDay() then
			colorCorrection.Brightness = config.DayExposure
		else
			colorCorrection.Brightness = config.NightExposure
		end
		
		-- GARANTIR SEM NEVOA
		Lighting.FogEnd = 1e10
		
		-- GARANTIR BRILHO
		Lighting.Brightness = 0
		
		task.wait(config.UpdateDelay)
	end
end)

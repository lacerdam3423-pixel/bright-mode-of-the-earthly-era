--// CONFIG
local config = {
	Brightness = 2,
	AmbientColor = Color3.fromRGB(200, 200, 200),
	OutdoorAmbient = Color3.fromRGB(180, 180, 180),

	BlackToColor = Color3.fromRGB(180, 180, 180),

	MaxTransparency = 0.95
}

--// SERVICES
local Lighting = game:GetService("Lighting")

--// ===== BRIGHT MODE + LOW GRAPHICS =====
Lighting.Brightness = config.Brightness
Lighting.GlobalShadows = false
Lighting.FogEnd = 1000000
Lighting.FogStart = 1000000
Lighting.FogColor = Color3.new(1,1,1)

Lighting.Ambient = config.AmbientColor
Lighting.OutdoorAmbient = config.OutdoorAmbient

Lighting.Technology = Enum.Technology.Compatibility

--// REMOVER TUDO PESADO DO LIGHTING
for _, v in ipairs(Lighting:GetChildren()) do
	if v:IsA("PostEffect")
	or v:IsA("Atmosphere")
	or v:IsA("Sky")
	or v:IsA("BloomEffect")
	or v:IsA("ColorCorrectionEffect")
	or v:IsA("SunRaysEffect")
	or v:IsA("DepthOfFieldEffect") then
		v:Destroy()
	end
end

--// FUNÇÃO ULTRA OTIMIZADA
local function optimize(obj)

	-- LUZES
	if obj:IsA("PointLight")
	or obj:IsA("SpotLight")
	or obj:IsA("SurfaceLight") then
		obj.Enabled = false
		return
	end

	-- PARTES
	if obj:IsA("BasePart") then

		-- sem sombra
		obj.CastShadow = false

		-- cor preta -> cinza
		local c = obj.Color
		if c.R < 0.1 and c.G < 0.1 and c.B < 0.1 then
			obj.Color = config.BlackToColor
		end

		-- materiais leves
		if obj.Material ~= Enum.Material.SmoothPlastic then
			obj.Material = Enum.Material.SmoothPlastic
		end

		-- transparência bugada
		if obj.Transparency >= 1 then
			obj.Transparency = config.MaxTransparency
		end
	end

	-- TEXTURAS / DECALS (peso grande)
	if obj:IsA("Decal") or obj:IsA("Texture") then
		obj:Destroy()
	end

	-- PARTICLES (muito pesado)
	if obj:IsA("ParticleEmitter")
	or obj:IsA("Trail")
	or obj:IsA("Smoke")
	or obj:IsA("Fire")
	or obj:IsA("Sparkles") then
		obj.Enabled = false
	end

	-- BEAMS / RAY FX
	if obj:IsA("Beam") then
		obj.Enabled = false
	end
end

--// APLICAR UMA VEZ (sem loop pesado)
for _, obj in ipairs(workspace:GetDescendants()) do
	optimize(obj)
end

--// NOVOS OBJETOS (SEM WAIT LENTO)
workspace.DescendantAdded:Connect(optimize)

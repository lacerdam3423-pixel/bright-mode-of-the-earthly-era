-- Script Profissional: Permanent Ultra Bright & Performance
-- Configurações fixas: Sem Botão, Sem Lag, Brilho Máximo

local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")

-- 1. Configuração de Iluminação Fixa
local function ApplyPermanentBright()
    -- Aplica os valores solicitados
    Lighting.Brightness = 0
    Lighting.ExposureCompensation = 0.5
    
    -- Força o estado de "Dia Eterno" e remove sombras
    Lighting.ClockTime = 12
    Lighting.GlobalShadows = false
    Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
    Lighting.Ambient = Color3.fromRGB(255, 255, 255)
    
    -- Remove efeitos de pós-processamento (Bloom/Blur)
    for _, effect in pairs(Lighting:GetChildren()) do
        if effect:IsA("BloomEffect") or effect:IsA("BlurEffect") or effect:IsA("DepthOfFieldEffect") then
            effect.Enabled = false
        end
    end
end

-- 2. Otimização de Materiais e Peças
local function OptimizeWorld()
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            -- Desativa sombras individuais para ganho de FPS
            obj.CastShadow = false
            
            -- Transforma Neon em Metal
            if obj.Material == Enum.Material.Neon then
                obj.Material = Enum.Material.Metal
            end
        end
    end
end

-- 3. Proteção Anti-Mudança (Mantém o brilho se o jogo tentar mudar)
Lighting:GetPropertyChangedSignal("ClockTime"):Connect(function()
    Lighting.ClockTime = 12
end)

Lighting:GetPropertyChangedSignal("GlobalShadows"):Connect(function()
    Lighting.GlobalShadows = false
end)

-- Execução Única e Direta
ApplyPermanentBright()
OptimizeWorld()

print("Bright Mode Permanente Ativado. Sistema de botão removido.")

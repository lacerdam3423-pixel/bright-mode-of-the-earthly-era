-- BRIGHT MODE ULTRA UNIVERSAL (ZERO LAG - TODOS OS JOGOS)
local Lighting = game:GetService("Lighting")
local TweenService = game:GetService("TweenService")

-- 1. CONFIGURAÇÃO DE CLIMA (LAVADO E SEM SOMBRAS)
local function ConfigurarLuz()
    Lighting.Brightness = 0
    Lighting.GlobalShadows = false
    Lighting.Ambient = Color3.new(1, 1, 1)
    Lighting.OutdoorAmbient = Color3.new(1, 1, 1)
    Lighting.FogEnd = 100000
    Lighting.FogStart = 0
    
    local atmos = Lighting:FindFirstChildOfClass("Atmosphere")
    if atmos then atmos:Destroy() end
end

-- 2. TRANSIÇÃO SUAVE
local function mudarClima(valorExposicao)
    local info = TweenInfo.new(2, Enum.EasingStyle.Linear)
    TweenService:Create(Lighting, info, {ExposureCompensation = valorExposicao}):Play()
end

local function atualizarCiclo()
    local hora = Lighting.ClockTime
    if hora >= 6 and hora <= 18 then
        mudarClima(0.5)
    else
        mudarClima(0.8)
    end
end

-- 3. FUNÇÃO DE AJUSTE (FIEL ÀS SUAS REGRAS)
local function ajustarObjeto(obj)
    if obj:IsA("BasePart") then
        -- Neon vira Ice
        if obj.Material == Enum.Material.Neon then
            obj.Material = Enum.Material.Ice
        end
        -- Invisível (1) vira 0.7
        if obj.Transparency >= 0.98 then
            obj.Transparency = 0.7
        end
    end
end

-- 4. VARREDURA INICIAL OTIMIZADA (SÓ RODA UMA VEZ)
ConfigurarLuz()
task.spawn(function()
    local itens = workspace:GetDescendants()
    for i = 1, #itens do
        pcall(ajustarObjeto, itens[i])
        -- Pausa para o Moto E40 respirar
        if i % 80 == 0 then task.wait() end
    end
end)

-- 5. MONITORAMENTO DE NOVOS OBJETOS (UNIVERSAL)
-- Isso evita que o script precise ler o mapa todo a cada segundo
workspace.DescendantAdded:Connect(function(obj)
    pcall(ajustarObjeto, obj)
end)

-- 6. LOOP DE MANUTENÇÃO LEVE (CADA 1 SEGUNDO)
Lighting:GetPropertyChangedSignal("ClockTime"):Connect(atualizarCiclo)
atualizarCiclo()

task.spawn(function()
    while true do
        ConfigurarLuz() -- Mantém a luz sem neblina
        task.wait(1)
    end
end)

print("Bright Mode Universal: Roda Liso em qualquer jogo!")

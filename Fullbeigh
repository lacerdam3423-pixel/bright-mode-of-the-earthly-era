--// CONFIG
local config = {
	Brightness = 0,
	AmbientColor = Color3.fromRGB(200, 200, 200),
	OutdoorAmbient = Color3.fromRGB(180, 180, 180),

	DayExposure = 0,
	NightExposure = 0,

	ForceWhiteFromBlack = true,
	ConvertNeon = true,
	RemoveShadows = true,
	DisableLights = true,
	AdjustTransparency = true,
	SmoothLighting = false
}

--// SERVICES
local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")

--// BASE LIGHTING SETUP
Lighting.Brightness = config.Brightness
Lighting.GlobalShadows = false
Lighting.FogEnd = 1000000
Lighting.FogStart = 1000000
Lighting.FogColor = Color3.new(1,1,1)
Lighting.Ambient = config.AmbientColor
Lighting.OutdoorAmbient = config.OutdoorAmbient

-- Remove efeitos
for _, v in ipairs(Lighting:GetChildren()) do
	if v:IsA("PostEffect") then
		v:Destroy()
	end
end

--// FUNÇÃO DE AJUSTE DE PARTES
local function processPart(part)
	if not part:IsA("BasePart") then return end

	-- Remover sombras
	if config.RemoveShadows then
		part.CastShadow = false
	end

	-- Converter Neon
	if config.ConvertNeon and part.Material == Enum.Material.Neon then
		part.Material = Enum.Material.SmoothPlastic
	end

	-- Ajustar transparência
	if config.AdjustTransparency and part.Transparency >= 1 then
		part.Transparency = 0.95
	end

	-- Converter preto para cinza claro
	if config.ForceWhiteFromBlack then
		local c = part.Color
		if c.R < 0.1 and c.G < 0.1 and c.B < 0.1 then
			part.Color = Color3.fromRGB(180,180,180)
		end
	end
end

--// REMOVER LUZES DINÂMICAS
local function disableLights(obj)
	if not config.DisableLights then return end

	if obj:IsA("PointLight") 
	or obj:IsA("SpotLight") 
	or obj:IsA("SurfaceLight") then
		obj.Enabled = false
	end
end

--// LOOP INICIAL
for _, obj in ipairs(workspace:GetDescendants()) do
	processPart(obj)
	disableLights(obj)
end

--// NOVOS OBJETOS
workspace.DescendantAdded:Connect(function(obj)
	task.wait()
	processPart(obj)
	disableLights(obj)
end)

--// SISTEMA DAY/NIGHT (sem travar ClockTime)
RunService.RenderStepped:Connect(function()
	local time = Lighting.ClockTime

	if time >= 6 and time <= 18 then
		Lighting.ExposureCompensation = config.DayExposure
	else
		Lighting.ExposureCompensation = config.NightExposure
	end
end)

--// GARANTIA FINAL
Lighting.EnvironmentDiffuseScale = 0
Lighting.EnvironmentSpecularScale = 0
Lighting.ShadowSoftness = 0

print("✔ BrightMode carregado com sucesso")

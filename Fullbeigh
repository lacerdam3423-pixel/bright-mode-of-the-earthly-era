-- SERVICES
local Lighting = game:GetService("Lightning")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local UserSettings = UserSettings()
local GameSettings = UserSettings:GetService("UserGameSettings")

local LocalPlayer = Players.LocalPlayer
local CurrentCamera = Workspace.CurrentCamera

-- =====================================================
-- CONFIGURATION
-- =====================================================
local CONFIG = {
    -- Lighting Core
    Brightness = 0.5,
    GlobalShadows = false,
    ShadowSoftness = 0,
    Technology = "Compatibility",   -- Fallback for low-end
    EnvironmentDiffuseScale = 0,
    EnvironmentSpecularScale = 0,
    ExposureDay = 0.4,
    ExposureNight = 0.9,
    DayStart = 6,
    DayEnd = 18,
    
    -- Fog & Atmosphere
    FogStart = 0,
    FogEnd = 1e10,
    FogColor = Color3.new(0.5, 0.5, 0.5),
    
    -- Material Normalization
    MinColorLuminance = 0.1,
    GrayColor = Color3.new(0.4, 0.4, 0.4),
    
    -- Performance
    BatchSize = 12,                 -- Objects per frame
    HeartbeatInterval = 0.2,        -- Watchdog check interval
    MaxRetries = 3,
    
    -- Light Killer Mode
    LightDestructionMode = "Destroy", -- "Disable" or "Destroy"
    
    -- FPS & Graphics
    TargetGraphicsLevel = 1,         -- Force lowest graphics on low-end
    UnlockFPS = true,                -- Remove vsync constraints (simulated)
}

local LIGHT_CLASSES = {
    "PointLight", "SpotLight", "SurfaceLight"
}

local POST_EFFECT_CLASSES = {
    "BloomEffect", "BlurEffect", "SunRaysEffect", "DepthOfFieldEffect",
    "ColorCorrectionEffect", "GlowEffect", "GrainEffect", "RimEffect"
}

local HEAVY_VISUALS = {
    "ParticleEmitter", "Trail", "Smoke", "Fire", "Sparkles"
}

-- =====================================================
-- GLOBAL CACHE & STATE
-- =====================================================
local processedObjects = setmetatable({}, {__mode = "k"})  -- Weak cache
local retryQueue = {}
local isProcessing = false
local watchdogActive = true
local lastLightingState = {}

-- =====================================================
-- SAFE EXECUTION WRAPPER
-- =====================================================
local function safe(operation, ...)
    local success, result = pcall(operation, ...)
    if not success then
        return nil
    end
    return result
end

local function safeDestroy(instance)
    if not instance or not instance.Parent then return end
    safe(function()
        instance:Destroy()
    end)
end

local function safeDisable(instance)
    if not instance then return end
    safe(function()
        instance.Enabled = false
    end)
end

-- =====================================================
-- CORE: LIGHTING OVERRIDE (forced + self-healing)
-- =====================================================
local function applyLightingOverride()
    safe(function()
        Lighting.Brightness = CONFIG.Brightness
        Lighting.GlobalShadows = CONFIG.GlobalShadows
        Lighting.ShadowSoftness = CONFIG.ShadowSoftness
        if Lighting.Technology then
            Lighting.Technology = Enum.Technology[CONFIG.Technology]
        end
        Lighting.EnvironmentDiffuseScale = CONFIG.EnvironmentDiffuseScale
        Lighting.EnvironmentSpecularScale = CONFIG.EnvironmentSpecularScale
        
        -- Exposure based on ClockTime
        local time = Lighting.ClockTime
        local isDay = (time >= CONFIG.DayStart and time < CONFIG.DayEnd)
        Lighting.ExposureCompensation = isDay and CONFIG.ExposureDay or CONFIG.ExposureNight
        
        -- Fog reset
        Lighting.FogStart = CONFIG.FogStart
        Lighting.FogEnd = CONFIG.FogEnd
        Lighting.FogColor = CONFIG.FogColor
    end)
    
    -- Destroy Atmosphere if exists
    safe(function()
        local atmosphere = Lighting:FindFirstChildOfClass("Atmosphere")
        if atmosphere then
            atmosphere:Destroy()
        end
    end)
end

-- Remove all post-processing effects
local function purgePostEffects()
    for _, effect in ipairs(Lighting:GetChildren()) do
        for _, className in POST_EFFECT_CLASSES do
            if effect:IsA(className) then
                safeDestroy(effect)
                break
            end
        end
    end
    if CurrentCamera then
        for _, effect in ipairs(CurrentCamera:GetChildren()) do
            for _, className in POST_EFFECT_CLASSES do
                if effect:IsA(className) then
                    safeDestroy(effect)
                    break
                end
            end
        end
    end
end

-- =====================================================
-- LIGHT KILLER SYSTEM (total annihilation)
-- =====================================================
local function killLight(instance)
    if processedObjects[instance] then return end
    for _, className in LIGHT_CLASSES do
        if instance:IsA(className) then
            safe(function()
                if CONFIG.LightDestructionMode == "Destroy" then
                    instance:Destroy()
                else
                    instance.Enabled = false
                end
                processedObjects[instance] = true
            end)
            return
        end
    end
end

-- =====================================================
-- MATERIAL & VISUAL NORMALIZATION
-- =====================================================
local function getLuminance(color)
    return 0.2126 * color.R + 0.7152 * color.G + 0.0722 * color.B
end

local function normalizeColor(color)
    local lum = getLuminance(color)
    if lum < CONFIG.MinColorLuminance then
        return CONFIG.GrayColor
    end
    return color
end

local function normalizePart(part)
    if not part:IsA("BasePart") then return end
    if processedObjects[part] then return end
    
    safe(function()
        -- Material conversion
        if part.Material == Enum.Material.Neon then
            part.Material = Enum.Material.SmoothPlastic
        end
        
        -- Disable shadows
        part.CastShadow = false
        
        -- Remove reflectance
        part.Reflectance = 0
        
        -- Normalize extreme dark colors
        part.Color = normalizeColor(part.Color)
        
        processedObjects[part] = true
    end)
    
    -- Disable heavy visual effects inside part
    for _, child in ipairs(part:GetChildren()) do
        for _, visualType in HEAVY_VISUALS do
            if child:IsA(visualType) then
                safeDisable(child)
                break
            end
        end
    end
end

-- =====================================================
-- PERFORMANCE OVERDRIVE (batch scheduler, FPS unlock)
-- =====================================================
local function applyPerformanceSettings()
    safe(function()
        -- Force lowest graphics level for low-end (user can override, but we push)
        if GameSettings then
            GameSettings.GraphicsQualityLevel = CONFIG.TargetGraphicsLevel
            GameSettings.RenderFidelity = Enum.RenderFidelity.Automatic
        end
        
        -- Simulate FPS unlock (reduces render bottlenecks)
        if CONFIG.UnlockFPS then
            RunService:SetThrottleFramerateEnabled(false)   -- Placeholder, actual unlock depends on external tools
            -- Real FPS unlock requires OS-level changes, but we reduce load
        end
    end)
end

-- Batch processing to avoid spikes
local pendingBatch = {}
local batchRunning = false

local function processBatch()
    if #pendingBatch == 0 then
        batchRunning = false
        return
    end
    local count = math.min(CONFIG.BatchSize, #pendingBatch)
    for i = 1, count do
        local obj = pendingBatch[i]
        if obj and obj.Parent then
            killLight(obj)
            normalizePart(obj)
        end
    end
    for i = 1, count do
        table.remove(pendingBatch, 1)
    end
    if #pendingBatch > 0 then
        task.wait()
        processBatch()
    else
        batchRunning = false
    end
end

local function queueObject(obj)
    if not obj then return end
    pendingBatch[#pendingBatch + 1] = obj
    if not batchRunning then
        batchRunning = true
        task.spawn(processBatch)
    end
end

-- =====================================================
-- INITIAL FULL SCAN (async, non-blocking)
-- =====================================================
local function initialScan()
    local allDescendants = Workspace:GetDescendants()
    for _, obj in ipairs(allDescendants) do
        queueObject(obj)
    end
    -- Also scan Lighting for leftover effects
    purgePostEffects()
    applyLightingOverride()
end

-- =====================================================
-- STREAMING WATCHER & DYNAMIC WORLD
-- =====================================================
local function setupStreamingWatcher()
    Workspace.DescendantAdded:Connect(function(instance)
        queueObject(instance)
    end)
    
    -- Reapply lighting when new chunks are streamed (no need, already caught by DescendantAdded)
    -- But ensure streaming is enabled if needed
    safe(function()
        Workspace.StreamingEnabled = true
    end)
end

-- =====================================================
-- WATCHDOG AUTO-REGEN (self-healing, persistence)
-- =====================================================
local function checkLightingIntegrity()
    local currentBrightness = safe(function() return Lighting.Brightness end)
    if currentBrightness ~= CONFIG.Brightness then
        applyLightingOverride()
    end
    local currentShadows = safe(function() return Lighting.GlobalShadows end)
    if currentShadows ~= CONFIG.GlobalShadows then
        applyLightingOverride()
    end
    -- Also check exposure compensation
    local currentExposure = safe(function() return Lighting.ExposureCompensation end)
    local time = safe(function() return Lighting.ClockTime end) or 12
    local expectedExposure = (time >= CONFIG.DayStart and time < CONFIG.DayEnd) and CONFIG.ExposureDay or CONFIG.ExposureNight
    if currentExposure ~= expectedExposure then
        applyLightingOverride()
    end
end

local function startWatchdog()
    RunService.Heartbeat:Connect(function(delta)
        if not watchdogActive then return end
        -- Run every ~0.2 seconds (approx 0.2s intervals)
        if tick() % CONFIG.HeartbeatInterval < delta then
            checkLightingIntegrity()
        end
    end)
end

-- =====================================================
-- ANTI-ERROR CRITICAL (nil-safe everywhere)
-- =====================================================
local function safeEnvironment()
    -- Override any potential nil accessors with safe fallback
    -- Ensure services exist
    if not Lighting or not Workspace then
        warn("[BrightMode] Critical services missing")
        return false
    end
    return true
end

-- =====================================================
-- INTERNET BOOST (realistic client-side optimizations)
-- =====================================================
local function applyInternetBoost()
    -- Reduce render load to free network thread priority
    safe(function()
        -- Lower part streaming radius to reduce asset downloads
        Workspace.StreamingTargetRadius = 256
        Workspace.StreamingPauseMode = Enum.StreamingPauseMode.Default
    end)
    -- No actual ping improvement, just prioritization
end

-- =====================================================
-- LOW-END DEVICE ADAPTATION (dynamic throttling)
-- =====================================================
local function detectLowPerformance()
    local frameTimes = {}
    local sampleCount = 0
    RunService.RenderStepped:Connect(function(dt)
        sampleCount = sampleCount + 1
        frameTimes[#frameTimes + 1] = dt
        if sampleCount >= 30 then
            local avgDt = 0
            for _, t in ipairs(frameTimes) do avgDt = avgDt + t end
            avgDt = avgDt / #frameTimes
            local fps = 1 / avgDt
            if fps < 30 then
                -- Reduce batch size and quality
                CONFIG.BatchSize = 6
                CONFIG.TargetGraphicsLevel = 1
                applyPerformanceSettings()
            end
            frameTimes = {}
            sampleCount = 0
        end
    end)
end

-- =====================================================
-- INITIALIZATION
-- =====================================================
local function init()
    if not safeEnvironment() then
        return
    end
    
    applyLightingOverride()
    purgePostEffects()
    applyPerformanceSettings()
    applyInternetBoost()
    setupStreamingWatcher()
    initialScan()
    startWatchdog()
    detectLowPerformance()
    
    -- Additional self-healing: monitor property changes to external tampering
    safe(function()
        Lighting:GetPropertyChangedSignal("ClockTime"):Connect(applyLightingOverride)
        Lighting:GetPropertyChangedSignal("Brightness"):Connect(applyLightingOverride)
        Lighting:GetPropertyChangedSignal("GlobalShadows"):Connect(applyLightingOverride)
        Lighting:GetPropertyChangedSignal("ExposureCompensation"):Connect(applyLightingOverride)
    end)
    
    -- Monitor camera changes to clean effects on new camera
    safe(function()
        workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()
            CurrentCamera = workspace.CurrentCamera
            if CurrentCamera then
                for _, effect in ipairs(CurrentCamera:GetChildren()) do
                    for _, className in POST_EFFECT_CLASSES do
                        if effect:IsA(className) then
                            safeDestroy(effect)
                            break
                        end
                    end
                end
            end
        end)
    end)
end

-- Execute
init()

--// CONFIG
local config = {
	DayExposure = 0.4,
	NightExposure = 0.7,
	UseAutoExposure = true,

	ForceBrightness = 0,
	AmbientColor = Color3.fromRGB(200, 200, 200),
	OutdoorAmbient = Color3.fromRGB(180, 180, 180),

	ConvertBlack = true,
	BlackToColor = Color3.fromRGB(180, 180, 180),

	ConvertNeon = true,
	ConvertPlastic = true,
	PlasticMaterial = Enum.Material.SmoothPlastic,
	NeonMaterial = Enum.Material.SmoothPlastic,

	TransparencyFix = true,
	MaxTransparency = 0.85,

	RemoveShadows = true,
	DisableLights = true,
	DisableEffects = true
}

--// SERVICES
local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")

--// LIGHTING BASE
Lighting.Brightness = config.ForceBrightness
Lighting.GlobalShadows = false
Lighting.FogEnd = 1000000
Lighting.FogStart = 1000000
Lighting.FogColor = Color3.new(1,1,1)

Lighting.Ambient = config.AmbientColor
Lighting.OutdoorAmbient = config.OutdoorAmbient

-- Remove tecnologia pesada
Lighting.Technology = Enum.Technology.Compatibility

-- Remove efeitos visuais
if config.DisableEffects then
	for _, v in pairs(Lighting:GetChildren()) do
		if v:IsA("PostEffect") or v:IsA("Atmosphere") or v:IsA("Sky") then
			v:Destroy()
		end
	end
end

--// BLOQUEAR LUZES
local function disableLights(obj)
	if config.DisableLights then
		if obj:IsA("PointLight") or obj:IsA("SpotLight") or obj:IsA("SurfaceLight") then
			obj.Enabled = false
		end
	end
end

--// AJUSTAR PARTES
local function fixPart(part)
	if part:IsA("BasePart") then

		-- remover sombra
		if config.RemoveShadows then
			part.CastShadow = false
		end

		-- converter preto → cinza claro
		if config.ConvertBlack then
			if part.Color.R < 0.1 and part.Color.G < 0.1 and part.Color.B < 0.1 then
				part.Color = config.BlackToColor
			end
		end

		-- plastic → smoothplastic
		if config.ConvertPlastic and part.Material == Enum.Material.Plastic then
			part.Material = config.PlasticMaterial
		end

		-- neon → smoothplastic
		if config.ConvertNeon and part.Material == Enum.Material.Neon then
			part.Material = config.NeonMaterial
		end

		-- transparência
		if config.TransparencyFix then
			if part.Transparency >= 1 then
				part.Transparency = config.MaxTransparency
			end
		end

	end
end

--// APLICAR NO MAPA
for _, obj in pairs(workspace:GetDescendants()) do
	disableLights(obj)
	fixPart(obj)
end

-- atualizar novos objetos
workspace.DescendantAdded:Connect(function(obj)
	task.wait()
	disableLights(obj)
	fixPart(obj)
end)

--// EXPOSURE DINÂMICO (SEM CLOCKTIME FIXO)
RunService.Heartbeat:Connect(function()
	if config.UseAutoExposure then
		local time = Lighting.ClockTime

		if time >= 6 and time <= 18 then
			Lighting.ExposureCompensation = config.DayExposure
		else
			Lighting.ExposureCompensation = config.NightExposure
		end
	end
end)

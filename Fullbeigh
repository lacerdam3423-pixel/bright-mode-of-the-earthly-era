--[[
    Bright Mode + Performance Optimizer
    - Aumenta visibilidade (Exposure dinâmico)
    - Remove luzes dinâmicas e efeitos pesados
    - Normaliza materiais e cores escuras
    - Otimiza FPS em dispositivos fracos
    - Roda sozinho, sem travamentos
    Baseado em práticas reais de otimização.
]]

local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")

-- ========================
-- CONFIGURAÇÃO
-- ========================
local CONFIG = {
    Brightness = 0.1,
    GlobalShadows = false,
    ShadowSoftness = 0,
    Technology = "Compatibility",   -- Melhor para FPS
    ExposureDay = 0.4,              -- Visibilidade diurna limpa
    ExposureNight = 1.2,            -- Noite bem iluminada
    DayStart = 6,
    DayEnd = 18,
    FogStart = 0,
    FogEnd = 1e9,                   -- Remove neblina
    FogColor = Color3.new(0.5, 0.5, 0.5),
    MinLuminance = 0.15,            -- Preto mínimo
    GrayBalance = Color3.new(0.35, 0.35, 0.35),
    BatchSize = 30,                 -- Objetos por lote inicial
}

-- Classes de luz a serem desativadas
local LIGHT_TYPES = { "PointLight", "SpotLight", "SurfaceLight" }

-- Efeitos de pós-processamento a destruir
local POST_EFFECTS = {
    "BloomEffect", "BlurEffect", "SunRaysEffect",
    "ColorCorrectionEffect", "DepthOfFieldEffect"
}

-- Partículas e efeitos pesados a desligar
local HEAVY_EFFECTS = { "ParticleEmitter", "Trail", "Smoke", "Fire", "Sparkles" }

-- Cache de objetos já processados (weak table)
local processed = setmetatable({}, { __mode = "k" })

-- ========================
-- FUNÇÕES SEGURAS (pcall)
-- ========================
local function safeCall(func, ...)
    local ok = pcall(func, ...)
    if not ok then
        -- Silencia erro para não parar o script
    end
    return ok
end

local function safeDestroy(obj)
    if obj and obj.Parent then
        safeCall(function() obj:Destroy() end)
    end
end

local function safeDisable(obj)
    if obj and obj.Parent then
        safeCall(function() obj.Enabled = false end)
    end
end

-- ========================
-- NÚCLEO DE ILUMINAÇÃO
-- ========================
local function applyLighting()
    safeCall(function()
        Lighting.Brightness = CONFIG.Brightness
        Lighting.GlobalShadows = CONFIG.GlobalShadows
        Lighting.ShadowSoftness = CONFIG.ShadowSoftness
        if Lighting.Technology then
            Lighting.Technology = Enum.Technology[CONFIG.Technology]
        end
        -- Fog
        Lighting.FogStart = CONFIG.FogStart
        Lighting.FogEnd = CONFIG.FogEnd
        Lighting.FogColor = CONFIG.FogColor
        
        -- Exposure dinâmico baseado no horário
        local time = Lighting.ClockTime
        local isDay = time >= CONFIG.DayStart and time < CONFIG.DayEnd
        Lighting.ExposureCompensation = isDay and CONFIG.ExposureDay or CONFIG.ExposureNight
    end)
    
    -- Remove Atmosphere se existir
    safeCall(function()
        local atm = Lighting:FindFirstChildOfClass("Atmosphere")
        if atm then atm:Destroy() end
    end)
end

-- ========================
-- REMOÇÃO DE PÓS-EFEITOS
-- ========================
local function removePostEffects()
    safeCall(function()
        for _, child in ipairs(Lighting:GetChildren()) do
            for _, cls in ipairs(POST_EFFECTS) do
                if child:IsA(cls) then
                    safeDestroy(child)
                    break
                end
            end
        end
        -- Câmera atual também pode ter efeitos
        local cam = workspace.CurrentCamera
        if cam then
            for _, child in ipairs(cam:GetChildren()) do
                for _, cls in ipairs(POST_EFFECTS) do
                    if child:IsA(cls) then
                        safeDestroy(child)
                        break
                    end
                end
            end
        end
    end)
end

-- ========================
-- SUPRESSÃO DE LUZES DINÂMICAS
-- ========================
local function disableLight(instance)
    if processed[instance] then return end
    for _, cls in ipairs(LIGHT_TYPES) do
        if instance:IsA(cls) then
            safeDisable(instance)
            processed[instance] = true
            return
        end
    end
end

-- ========================
-- OTIMIZAÇÃO DE PARTES (Material, Cor, Sombras)
-- ========================
local function getLuminance(c)
    return 0.2126 * c.R + 0.7152 * c.G + 0.0722 * c.B
end

local function optimizePart(part)
    if not part:IsA("BasePart") then return end
    if processed[part] then return end
    
    safeCall(function()
        -- Neon -> SmoothPlastic (menos custo)
        if part.Material == Enum.Material.Neon then
            part.Material = Enum.Material.SmoothPlastic
        end
        
        -- Desativa sombras e reflexos
        part.CastShadow = false
        part.Reflectance = 0
        
        -- Corrige cores muito escuras
        local lum = getLuminance(part.Color)
        if lum < CONFIG.MinLuminance then
            part.Color = CONFIG.GrayBalance
        end
    end)
    
    -- Desativa efeitos pesados dentro da parte
    for _, child in ipairs(part:GetChildren()) do
        for _, eff in ipairs(HEAVY_EFFECTS) do
            if child:IsA(eff) then
                safeDisable(child)
                break
            end
        end
    end
    
    processed[part] = true
end

-- ========================
-- PROCESSAMENTO EM LOTE (INICIAL)
-- ========================
local function initialBatch()
    local all = Workspace:GetDescendants()
    local total = #all
    local i = 1
    
    while i <= total do
        local limit = math.min(i + CONFIG.BatchSize - 1, total)
        for idx = i, limit do
            local obj = all[idx]
            if obj and obj.Parent then
                disableLight(obj)
                optimizePart(obj)
            end
        end
        i = limit + 1
        task.wait() -- Yield para não travar o jogo
    end
    
    -- Finaliza efeitos
    removePostEffects()
    applyLighting()
end

-- ========================
-- REATIVIDADE (NOVOS OBJETOS)
-- ========================
local function setupReactivity()
    Workspace.DescendantAdded:Connect(function(obj)
        if not obj then return end
        -- Processa imediatamente (sem esperar lote)
        disableLight(obj)
        optimizePart(obj)
    end)
    
    -- Novos efeitos no Lighting
    Lighting.ChildAdded:Connect(function(child)
        for _, cls in ipairs(POST_EFFECTS) do
            if child:IsA(cls) then
                safeDestroy(child)
                break
            end
        end
        if child:IsA("Atmosphere") then
            safeDestroy(child)
        end
    end)
end

-- ========================
-- AUTO-HEALING (Watchdog leve)
-- ========================
local function startWatchdog()
    -- Reaplica iluminação sempre que uma propriedade crítica mudar
    local props = { "ClockTime", "Brightness", "GlobalShadows", "ExposureCompensation" }
    for _, prop in ipairs(props) do
        local signal = Lighting:GetPropertyChangedSignal(prop)
        if signal then
            signal:Connect(applyLighting)
        end
    end
    -- Verifica periodicamente a integridade (a cada 5 segundos)
    task.spawn(function()
        while true do
            task.wait(5)
            if Lighting.GlobalShadows ~= false then
                applyLighting()
            end
            if Lighting.FogStart ~= 0 or Lighting.FogEnd ~= CONFIG.FogEnd then
                applyLighting()
            end
        end
    end)
end

-- ========================
-- OTIMIZAÇÃO ADICIONAL (Gráficos)
-- ========================
local function applyGraphicsDefaults()
    safeCall(function()
        local UserSettings = UserSettings()
        local GameSettings = UserSettings:GetService("UserGameSettings")
        if GameSettings then
            -- Força nível gráfico baixo (1) para máximo FPS, mas sem travar
            if GameSettings.GraphicsQualityLevel > 3 then
                GameSettings.GraphicsQualityLevel = 3
            end
            GameSettings.RenderFidelity = Enum.RenderFidelity.Automatic
        end
    end)
end

-- ========================
-- INICIALIZAÇÃO PRINCIPAL
-- ========================
local function init()
    -- Primeiro, estabiliza iluminação e remove lixo visual
    applyLighting()
    removePostEffects()
    applyGraphicsDefaults()
    
    -- Processa objetos existentes (batch)
    initialBatch()
    
    -- Ativa listeners para novos objetos
    setupReactivity()
    
    -- Auto-healing
    startWatchdog()
end

-- Executa o script
init()
